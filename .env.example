# ─────────────────────────────────────────────────────────────
# DevTeam AI — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── OpenRouter Configuration (RECOMENDADO) ──────────────────
# OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
# OPENAI_API_BASE=https://openrouter.ai/api/v1

# ── Other LLM Providers (Alternativas) ───────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# ── Model Configuration ──────────────────────────────────────
# Para OpenRouter (recomendado):
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-4o-mini
ORCHESTRATOR_MODEL=openai/gpt-4o-mini
DEFAULT_MODEL=openai/gpt-4o-mini

# Para Ollama (local):
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen3:4b
# ORCHESTRATOR_MODEL=qwen3:4b
# OLLAMA_HOST=http://localhost:11434

# ── Supabase (optional — falls back to local SQLite) ─────────
# Get your connection string from Supabase Dashboard → Settings → Database
# SUPABASE_DB_URL=postgresql+psycopg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Application ──────────────────────────────────────────────
APP_NAME=DevTeam AI
ARTIFACTS_DIR=artifacts
DEBUG=false
