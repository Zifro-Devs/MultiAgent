# ─────────────────────────────────────────────────────────────
# DevTeam AI — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# ── Model Configuration ──────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
ORCHESTRATOR_MODEL=qwen3:4b
OLLAMA_HOST=http://localhost:11434

# ── Supabase (optional — falls back to local SQLite) ─────────
# Get your connection string from Supabase Dashboard → Settings → Database
# SUPABASE_DB_URL=postgresql+psycopg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Application ──────────────────────────────────────────────
APP_NAME=DevTeam AI
ARTIFACTS_DIR=artifacts
DEBUG=false
