# ─────────────────────────────────────────────────────────────
# DevTeam AI — Configuración con Supabase
# Ejemplo basado en tu proyecto: vxrdwigjhonnsbifbjws
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# ── Model Configuration ──────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
ORCHESTRATOR_MODEL=qwen3:4b
OLLAMA_HOST=http://localhost:11434

# ── Supabase Database ────────────────────────────────────────
# IMPORTANTE: Reemplaza [TU-PASSWORD] con tu contraseña real de Supabase
# 
# Para obtener la URL completa:
# 1. Ve a https://supabase.com/dashboard
# 2. Selecciona tu proyecto
# 3. Settings → Database → Connection string → URI
# 4. Copia la URL y reemplaza [YOUR-PASSWORD] con tu contraseña
#
# Formato correcto para tu proyecto:
SUPABASE_DB_URL=postgresql+psycopg://postgres.vxrdwigjhonnsbifbjws:[TU-PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Nota: La región (us-west-1) puede variar según donde creaste tu proyecto
# Verifica la URL exacta en tu dashboard de Supabase

# ── Application ──────────────────────────────────────────────
APP_NAME=DevTeam AI
ARTIFACTS_DIR=artifacts
DEBUG=false

# ─────────────────────────────────────────────────────────────
# DATOS QUE NO NECESITAS (son para frontend Next.js):
# ─────────────────────────────────────────────────────────────
# ❌ NEXT_PUBLIC_SUPABASE_URL (no lo uses aquí)
# ❌ NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY (no lo uses aquí)
#
# Solo necesitas SUPABASE_DB_URL para la conexión directa a PostgreSQL
